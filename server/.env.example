# MySQL
KG_MYSQL_HOST=127.0.0.1
KG_MYSQL_PORT=3306
KG_MYSQL_USER=root
KG_MYSQL_PASSWORD=change_me
KG_MYSQL_DATABASE=knowledge_graph_db

# Neo4j
KG_NEO4J_URI=bolt://localhost:7687
KG_NEO4J_USER=neo4j
KG_NEO4J_PASSWORD=change_me

# API 服务
KG_API_HOST=0.0.0.0
KG_API_PORT=8000
KG_API_RELOAD=0

# 项目根（用于解析 image_path 相对路径，留空则取 server/..）
KG_PROJECT_ROOT=

# 后台管理 token（留空则后台 CRUD 接口禁用）
KG_ADMIN_TOKEN=

# CLIP + FAISS（可选；未装 torch 时 image-search 自动降级到 pHash）
KG_CLIP_MODEL=openai/clip-vit-base-patch32
KG_CLIP_INDEX_DIR=
